NODE_ENV=production

PORT=3001

# --- MySQL (aaPanel — khuyến nghị) ---
# • setup_server.sh KHÔNG cài mariadb-server (tránh xung đột MySQL của aaPanel).
# • Tạo DB trong aaPanel: Databases → Add DB (utf8mb4), user/mật khẩu, Permission: Local server (127.0.0.1).
# • Chạy setup: nhập mật khẩu khi được hỏi, hoặc export HTQL_SETUP_MYSQL_PASSWORD='...' (không commit mật khẩu).
# • Tương thích: DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASS (API map sang cùng nghĩa).
# • Tương thích file .env cũ: DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASS (API map sang cùng nghĩa).
# • Sau khi sửa .env: pm2 restart htql550-api

# --- Gốc cài (Ubuntu) — đồng bộ setup_server / chỉnh tay + aaPanel (MySQL) ---

HTQL_INSTALL_ROOT=/opt/htql550



# Dữ liệu JSON / registry (luôn dưới gốc cài trừ khi override)

HTQL_DATA_DIR=/opt/htql550/data



# SSD 2TB — hóa đơn/chứng từ (hdct) + thiết kế (thietke)

HTQL_ROOT_SSD=/ssd_2tb/htql_550

# SSD: hai thu muc tach biet — hdct + thietke (duong dan day du ben duoi).

HTQL_PATH_HOADON_CHUNG_TU=/ssd_2tb/htql_550/hdct

HTQL_PATH_THIET_KE=/ssd_2tb/htql_550/thietke

# Ảnh VTHH (tab Đặc tính — upload kind=vthh_hinh)

HTQL_PATH_VTHH_HINH_ANH=/ssd_2tb/htql_550/vthh

# Migration cấu trúc đính kèm cũ → mới (một lần; hoặc: cd server && npm run migrate-storage)
# HTQL_STORAGE_MIGRATE_ON_START=1


# HDD — backup

HTQL_PATH_BACKUP_DU_LIEU=/hdd_4tb/htql_550/backup_dulieu

HTQL_PATH_BACKUP_CT_TK=/hdd_4tb/htql_550/backup_ct_tk



# Gói cập nhật (mặc định = INSTALL_ROOT/update/…)

HTQL_UPDATE_CLIENT_DIR=/opt/htql550/update/client

HTQL_UPDATE_SERVER_DIR=/opt/htql550/update/server



# --- MySQL (aaPanel) — không commit mật khẩu ---

HTQL_MYSQL_HOST=127.0.0.1

HTQL_MYSQL_PORT=3306

HTQL_MYSQL_USER=htql_550

HTQL_MYSQL_PASSWORD=

HTQL_MYSQL_DATABASE=htql_550_db

# Phiên HTTP: cookie htql_sess + bảng htql_http_session (MySQL). Tắt ghi DB (chỉ cookie): HTQL_HTTP_SESSION_DB=0



# Tuỳ chọn: lần đầu tạo DB + user (cần mật khẩu admin MySQL; tắt sau khi xong)

# HTQL_MYSQL_BOOTSTRAP=1

# HTQL_MYSQL_ADMIN_USER=root

# HTQL_MYSQL_ADMIN_PASSWORD=



# --- Client build (Vite) — LAN / WAN / cổng API ---

# VITE_HTQL_IP_LAN=192.168.1.68

# VITE_HTQL_IP_PUBLIC=14.224.152.48

# VITE_HTQL_API_PORT=3001


