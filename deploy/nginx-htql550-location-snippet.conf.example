# HTQL_550 — Paste this `location` block inside an existing `server { }` in Nginx.
# aaPanel: Website -> pick domain -> Conf -> paste inside `server { }`, then Reload Nginx.
# Do not `apt install nginx` when aaPanel already manages Nginx under /www/server/nginx/.
# HTQL API Node listens on 127.0.0.1:3001

    location /api/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
