{
  "name": "htql-admin-tool",
  "version": "2.5.9",
  "private": true,
  "description": "HTQL_550 Server — tool quản trị SSH/PM2/MySQL (Windows Electron)",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV=1 electron .\"",
    "copy-icon": "node scripts/copy-icon.cjs",
    "build": "npm run copy-icon && vite build && electron-builder --win portable --x64",
    "build:vite": "vite build"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "vn.htql550.admin",
    "productName": "HTQL_550 Server",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["dist/**/*", "electron/**/*"],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "build/logo_nambac.png",
      "artifactName": "${productName}-${version}-Portable.${ext}",
      "signAndEditExecutable": false
    }
  }
}
