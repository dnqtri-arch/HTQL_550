# htql_550_map (maps) - Google Maps API Key
# Copy thành .env và điền key của bạn
VITE_HTQL_550_MAP_API_KEY=

# Gợi ý địa chỉ — Goong.io Place AutoComplete (ưu tiên). Tài liệu: https://docs.goong.io/rest/place
# Không đưa key thật vào repo — copy sang .env local và điền key của bạn
VITE_GOONG_API_KEY=

# Dự phòng: Openmap.vn — https://enterprise.openmap.vn/
VITE_OPENMAP_API_KEY=

# Nếu không có Goong/Openmap, app dùng Nominatim (miễn phí, giới hạn 1 request/giây)

# config_network.py - Địa chỉ IP (tránh hardcode trong code)
HTQL_550_IP_LAN=192.168.1.68
HTQL_550_IP_PUBLIC=14.224.152.48

# --- Client HTQL_550 (Vite) — kết nối API Node trên server thực (copy vào .env.production khi build) ---
# LAN nội bộ: 192.168.1.68 | Online: 14.224.152.48 | Cổng: 3001
VITE_HTQL_API_MODE=smart
VITE_HTQL_IP_LAN=192.168.1.68
VITE_HTQL_IP_PUBLIC=14.224.152.48
VITE_HTQL_API_PORT=3001

# --- Dev (npm run dev, Cursor): UI http://localhost:5174/ — dùng chung MySQL với máy chủ qua API ---
# Trình duyệt không kết nối MySQL trực tiếp; đặt VITE_* để gọi đúng API Node (cùng DB với client EXE nếu cùng IP:3001).
# Sao chép vào .env.development (file mẫu trong repo) hoặc bật thủ công:
# VITE_HTQL_DEV_USE_REMOTE_API=1
# VITE_HTTP_PROXY_API_TARGET=http://192.168.1.68:3001
# API cục bộ + MySQL (tunnel hoặc cùng credentials server): VITE_HTQL_DEV_USE_REMOTE_API=0, proxy http://127.0.0.1:3001, chạy node server/donViTinhServer.js với server/.env (không commit mật khẩu).
